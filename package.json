{
  "name": "@pbvision/service-api",
  "version": "0.0.1",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=./jest.config.json --coverage",
    "debug": "./node_modules/nodemon/bin/nodemon.js --no-lazy --legacy-watch --watch ./src --watch ./test --inspect=9229 node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=./jest.config.json --runInBand",
    "setup": "yarn install --frozen-lockfile",
    "start-local-db": "./node_modules/@pbvision/firestore-orm/scripts/start-local-db.sh",
    "start-local": "NODE_ENV=localhost process.env.FIRESTORE_EMULATOR_HOST = '[::1]:8404' node src/server.js",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=./jest.config.json --watch"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pbv-public/service-api"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@pbvision/fastify-firestore-service": "^0.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.17.12",
    "@babel/eslint-parser": "^7.17.0",
    "@babel/preset-env": "^7.17.12",
    "@pbvision/jest-unit-test": "^0.2.3",
    "babel-loader": "^9.1.3",
    "eslint": "^8.22.0",
    "eslint-config-standard": "17.1.0",
    "eslint-import-resolver-webpack": "^0.13.8",
    "eslint-plugin-import": "^2.22.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.0.0",
    "jest": "^29.7.0",
    "standard": "^17.1.0",
    "webpack": "^5.89.0"
  },
  "standard": {
    "envs": [
      "jest"
    ],
    "globals": [
      "fail"
    ],
    "ignore": [
      "**/node_modules/**"
    ],
    "parser": "@babel/eslint-parser"
  }
}
